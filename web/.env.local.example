# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional - for LLM switching)
OPENAI_API_KEY=sk-...

# Google Gemini (optional)
GEMINI_API_KEY=...

# DeepSeek (optional — https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — copy from Stripe Dashboard > Products > [product] > Pricing
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...
STRIPE_FAMILY_PRICE_ID=price_...
STRIPE_CLASSROOM_PRICE_ID=price_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend — https://resend.com, free tier 3000 emails/month)
# Required for parent notification emails on Explorer/Builder signups
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@yourdomain.com
